  startedAt              DateTime
  completedAt            DateTime?
  failedAt               DateTime?
  error                  String?
  totalScore             Float?
  maxScore               Float?
  metadata               Json
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

