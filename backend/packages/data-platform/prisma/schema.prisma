  answerGrades AssessmentAnswerGrade[]

  @@index([tenantId])
  @@index([workspaceId])
  @@index([attemptId])
  @@index([assessmentId])
  @@index([snapshotId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@index([failedAt])
  @@index([workspaceId, status])
  @@index([attemptId, startedAt])
}

model AssessmentAnswerGrade {
  id                  String                      @id @default(uuid()) @db.Uuid
  gradingRunId        String                      @db.Uuid
  attemptId           String                      @db.Uuid
  answerId            String                      @db.Uuid
  questionId          String                      @db.Uuid
  questionKind        AssessmentQuestionKind
  status              AssessmentAnswerGradeStatus @default(NOT_GRADED)
  method              AssessmentGradingMethod
  score               Float?
  maxScore            Float
  feedback            Json?
  gradedByPrincipalId String?                     @db.Uuid
  gradedAt            DateTime?
  metadata            Json
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  gradingRun AssessmentGradingRun    @relation(fields: [gradingRunId], references: [id], onDelete: Cascade)
  attempt    AssessmentAttempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  answer     AssessmentAttemptAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([gradingRunId, answerId])
  @@index([gradingRunId])
  @@index([attemptId])
  @@index([answerId])
  @@index([questionId])
  @@index([status])
  @@index([method])
  @@index([gradedAt])
}

