  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@index([status])
}

model AssessmentAttemptSession {
  id          String    @id @default(uuid()) @db.Uuid
  attemptId   String    @unique @db.Uuid
