  lastSeenAt  DateTime
  expiresAt   DateTime?
  submittedAt DateTime?
  metadata    Json

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([lastSeenAt])
}

model AssessmentAttemptResult {
  id            String                         @id @default(uuid()) @db.Uuid
  attemptId     String                         @unique @db.Uuid
  gradingStatus AssessmentAttemptGradingStatus @default(NOT_GRADED)
  score         Float?
  maxScore      Float?
  releasedAt    DateTime?
  feedback      Json?
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([gradingStatus])
  @@index([releasedAt])
}

model AssessmentGradingRun {
  id                     String                     @id @default(uuid()) @db.Uuid
  tenantId               String                     @db.Uuid
  workspaceId            String                     @db.Uuid
  attemptId              String                     @db.Uuid
  assessmentId           String                     @db.Uuid
  snapshotId             String                     @db.Uuid
