};

describe('assessment-attempt-state', () => {
  it('flattens snapshot questions in order', () => {
    const snapshot: AssessmentPublishedSnapshotContract = {
      id: 'snapshot-1',
      assessmentId: 'assessment-1',
      versionId: 'version-1',
      versionNumber: 1,
      publishedByPrincipalId: 'creator-1',
