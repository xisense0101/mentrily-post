          context and excluded from progress.
        </p>
      ) : null}
      <div className="mt-4 h-2 rounded-full bg-portal-surface-muted">
        <div
          className="h-2 rounded-full bg-portal-accent transition-[width]"
          style={{ width: `${progress}%` }}
        />
      </div>
    </section>
  );
}
