      kind: targetKind,
      tempFilePath: '/tmp/fixture-rendition.bin',
      mimeType: isThumbnail ? 'image/jpeg' : asset.contentType,
      sizeBytes: 1024 * 500, // 500KB
      ...(isThumbnail ? { width: 320, height: 240 } : { width: 1280, height: 720, durationSeconds: 120 }),
    };
  }
}
