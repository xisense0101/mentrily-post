interface SectionCreateFormProps {
  onSubmit: (input: AddLearningSectionRequest) => Promise<void> | void;
  isPending?: boolean;
}

export function SectionCreateForm({
  onSubmit,
  isPending = false,
}: SectionCreateFormProps) {
  const titleId = useId();
  const [title, setTitle] = useState('');
