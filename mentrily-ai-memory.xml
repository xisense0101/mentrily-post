export const MediaAssetStatuses = [
  'PENDING_UPLOAD',
  'UPLOADED',
  'PROCESSING_QUEUED',
  'PROCESSING',
  'AVAILABLE',
  'PROCESSING_FAILED',
  'ARCHIVED',
