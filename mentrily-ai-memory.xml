  isPublishing?: boolean | undefined;
  isArchiving?: boolean | undefined;
  isRestoring?: boolean | undefined;
  onSave?: (() => void) | undefined;
  onPublish?: (() => void) | undefined;
  onArchive?: (() => void) | undefined;
  onRestore?: (() => void) | undefined;
