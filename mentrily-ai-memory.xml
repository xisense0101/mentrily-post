      snapshotId: snapshot.id,
      snapshotVersionId: snapshot.versionId,
      snapshotVersionNumber: snapshot.versionNumber,
      learnerPrincipalId: TEST_ACTOR_ID,
      sessionId: '51000000-0000-4000-8000-000000000207',
