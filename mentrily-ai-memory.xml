export class CancelAssessmentCodeExecutionUseCase {
  constructor(
    @Inject(ASSESSMENT_EXECUTION_PROVIDER)
    private readonly executionProvider: AssessmentExecutionProvider,
    @Inject(PERMISSION_EVALUATOR) private readonly permissionEvaluator: PermissionEvaluator,
  ) {}

  async execute(context: RequestContext, executionRequestId: string): Promise<AssessmentExecutionResultResponse> {
