                <p className="text-xs text-slate-500">
                  {link.lessonId
                    ? 'Unlocks after lesson completion.'
                    : 'Available immediately at course level.'}
                </p>
              </div>
            </div>
          ))
        )}
      </div>
    </Card>
  );
}
