          ...(input.fileCategory ? { fileCategory: input.fileCategory } : {}),
          ...(input.ownerPrincipalId ? { ownerPrincipalId: input.ownerPrincipalId } : {}),
        },
        orderBy: [{ createdAt: 'desc' }, { id: 'asc' }],
