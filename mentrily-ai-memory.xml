): Prisma.AssessmentGradingRunUncheckedUpdateInput {
  return {
    triggeredByPrincipalId: run.triggeredByPrincipalId ?? null,
    status: run.status,
    completedAt: run.completedAt ?? null,
    failedAt: run.failedAt ?? null,
    error: run.error ?? null,
