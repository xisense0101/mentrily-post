  COURSE_CONTENT
  LESSON_CONTENT
  ASSESSMENT_CONTENT_RESERVED
  QUESTION_CONTENT_RESERVED
  GENERAL_PAGE
}

enum ContentDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentVersionStatus {
  DRAFT
  PUBLISHED_SNAPSHOT
  SUPERSEDED
}

enum BlockContentKind {
  PARAGRAPH
  HEADING
  SUBHEADING
  BULLET_LIST
  NUMBERED_LIST
  QUOTE
  CALLOUT
  DIVIDER
  IMAGE
  VIDEO
  EMBED
  FILE
  LINK
  CODE
  LESSON_REFERENCE
  SECTION_REFERENCE
  AI_PROMPT_PLACEHOLDER
  MCQ_QUESTION
  MULTI_SELECT_QUESTION
  CODE_QUESTION
  READING_PASSAGE
  RUBRIC
  GRADING_RULE
  NOTEBOOK_PROMPT
