// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Identity Models ---

enum PrincipalStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Principal {
  id          String          @id @default(uuid()) @db.Uuid
  email       String          @unique
  displayName String?
  status      PrincipalStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  externalIdentities ExternalIdentity[]
  accessSessions     AccessSession[]
  serviceCredentials ServiceCredential[]
  memberships        WorkspaceMember[]
  sentInvitations    Invitation[]        @relation("Inviter")

  @@index([email])
}

enum ExternalProvider {
  CLERK
  GOOGLE
  GITHUB
}

model ExternalIdentity {
  id          String           @id @default(uuid()) @db.Uuid
  principalId String           @db.Uuid
  provider    ExternalProvider
  externalId  String // e.g. Clerk User ID
  email       String
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  principal Principal @relation(fields: [principalId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([principalId])
  @@index([externalId])
}

model AccessSession {
  id          String   @id @default(uuid()) @db.Uuid
  principalId String   @db.Uuid
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  principal Principal @relation(fields: [principalId], references: [id], onDelete: Cascade)

  @@index([principalId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id                 String           @id @default(uuid()) @db.Uuid
  email              String
  workspaceId        String           @db.Uuid
  roleKey            String
  inviterPrincipalId String           @db.Uuid
  status             InvitationStatus @default(PENDING)
  token              String           @unique @default(uuid())
  expiresAt          DateTime
  acceptedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  inviter   Principal @relation("Inviter", fields: [inviterPrincipalId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email, workspaceId])
  @@index([token])
  @@index([status])
}

enum ServiceCredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ServiceCredential {
  id          String                  @id @default(uuid()) @db.Uuid
  principalId String                  @db.Uuid
  keyId       String                  @unique
  secretHash  String
  description String?
  status      ServiceCredentialStatus @default(ACTIVE)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  principal Principal @relation(fields: [principalId], references: [id], onDelete: Cascade)

  @@index([keyId])
}

// --- Workspace Governance Models ---

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Workspace {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  slug      String          @unique
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  members     WorkspaceMember[]
  roles       WorkspaceRole[]
  teams       Team[]
  domains     WorkspaceDomain[]
  branding    WorkspaceBranding?
  invitations Invitation[]

  @@index([slug])
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  REMOVED
}

model WorkspaceMember {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  principalId String           @db.Uuid
  status      MembershipStatus @default(ACTIVE)
  joinedAt    DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  principal       Principal             @relation(fields: [principalId], references: [id], onDelete: Cascade)
  teamMemberships TeamMember[]
  roles           WorkspaceMemberRole[]

  @@unique([workspaceId, principalId])
  @@index([workspaceId])
  @@index([principalId])
}

model WorkspaceMemberRole {
  id        String   @id @default(uuid()) @db.Uuid
  memberId  String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  member WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   WorkspaceRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@index([memberId])
  @@index([roleId])
}

model WorkspaceRole {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  key         String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  permissions WorkspacePermission[]
  memberRoles WorkspaceMemberRole[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model WorkspacePermission {
  id        String   @id @default(uuid()) @db.Uuid
  roleId    String   @db.Uuid
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role WorkspaceRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, key])
  @@index([roleId])
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TeamMember {
  id                String   @id @default(uuid()) @db.Uuid
  teamId            String   @db.Uuid
  workspaceMemberId String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  team            Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workspaceMember WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)

  @@unique([teamId, workspaceMemberId])
  @@index([teamId])
  @@index([workspaceMemberId])
}

enum WorkspaceDomainStatus {
  PENDING
  VERIFIED
  FAILED
}

model WorkspaceDomain {
  id                String                @id @default(uuid()) @db.Uuid
  workspaceId       String                @db.Uuid
  domain            String                @unique
  status            WorkspaceDomainStatus @default(PENDING)
  verificationToken String
  verifiedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([domain])
}

model WorkspaceBranding {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @unique @db.Uuid
  logoUrl      String?
  faviconUrl   String?
  primaryColor String?
  accentColor  String?
  customDomain String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// --- Audit & Event Foundation Models ---

model AuditRecord {
  id            String   @id @default(uuid()) @db.Uuid
  action        String
  actorId       String?  @db.Uuid
  targetType    String
  targetId      String?
  tenantId      String?  @db.Uuid
  workspaceId   String?  @db.Uuid
  requestId     String?
  correlationId String?
  metadata      Json?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@index([workspaceId])
  @@index([actorId])
  @@index([action])
  @@index([occurredAt])
}

enum OutboxMessageStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

model OutboxMessage {
  id             String              @id @default(uuid()) @db.Uuid
  eventId        String
  eventName      String
  eventVersion   Int
  tenantId       String?             @db.Uuid
  workspaceId    String?             @db.Uuid
  correlationId  String
  idempotencyKey String?
  payload        Json
  occurredAt     DateTime
  status         OutboxMessageStatus @default(PENDING)
  attemptCount   Int                 @default(0)
  availableAt    DateTime            @default(now())
  publishedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([eventId])
  @@index([status])
  @@index([availableAt])
  @@index([createdAt])
  @@index([workspaceId, status])
}

enum InboxMessageStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

model InboxMessage {
  id              String             @id @default(uuid()) @db.Uuid
  source          String
  externalEventId String
  eventName       String
  idempotencyKey  String?
  payloadHash     String
  status          InboxMessageStatus @default(RECEIVED)
  receivedAt      DateTime
  processedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([source, externalEventId])
  @@index([status])
  @@index([receivedAt])
}

// --- Learning Delivery Models (Task 008B) ---

enum LearningCourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LearningVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
  UNLISTED
}

enum LearningContentKind {
  TEXT
  VIDEO
  EMBED
  FILE
  LIVE_SESSION
  EXTERNAL_LINK
