NODE_ENV=test
APP_ENV=test

DATABASE_URL=postgresql://mentrily:mentrily@localhost:5433/mentrily_test?schema=public

# Media Processing
MEDIA_PROCESSING_HOOKS_ENABLED=false
MEDIA_DELIVERY_CDN_ENABLED=false
MEDIA_SECURITY_SCANNER_CLAMAV_ENABLED=false

# Communication Providers
COMMUNICATION_PROVIDER_MODE=NOOP
COMMUNICATION_EMAIL_PROVIDER=RESERVED_NONE
COMMUNICATION_SMS_PROVIDER=RESERVED_NONE
COMMUNICATION_EMAIL_PROVIDER_ENABLED=false
COMMUNICATION_SMS_PROVIDER_ENABLED=false
COMMUNICATION_ALLOW_LIVE_DELIVERY=false
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Communication Delivery Worker
COMMUNICATION_DELIVERY_WORKER_ENABLED=false
COMMUNICATION_DELIVERY_WORKER_INTERVAL_MS=30000
COMMUNICATION_DELIVERY_WORKER_BATCH_SIZE=25
COMMUNICATION_DELIVERY_MAX_ATTEMPTS=5
COMMUNICATION_DELIVERY_RETRY_BASE_MS=1000
