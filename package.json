{
  "name": "mentrily",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test --concurrency=1",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:env-examples": "node automation/verify-env-examples.mjs",
    "db:test:up": "docker-compose -f docker-compose.test.yml up -d postgres-test",
    "db:test:down": "docker-compose -f docker-compose.test.yml down -v",
    "test:integration": "node --env-file=.env.test automation/run-integration-tests.mjs",
    "test:e2e": "pnpm e2e:content && pnpm e2e:learning && pnpm e2e:assessment && pnpm e2e:assessment-attempt && pnpm e2e:assessment-grading && pnpm e2e:assessment-result",
    "e2e:content": "node --env-file=.env.test automation/run-content-e2e.mjs",
    "e2e:learning": "node --env-file=.env.test automation/run-learning-e2e.mjs",
    "prepare": "husky",
    "e2e:assessment": "node --env-file=.env.test automation/run-assessment-e2e.mjs",
    "e2e:assessment-attempt": "node --env-file=.env.test automation/run-assessment-attempt-e2e.mjs",
    "e2e:assessment-grading": "node --env-file=.env.test automation/run-assessment-grading-e2e.mjs",
    "e2e:assessment-result": "node --env-file=.env.test automation/run-assessment-result-e2e.mjs",
    "e2e:assessment-reliability": "node --env-file=.env.test automation/run-assessment-reliability-e2e.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.18",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.3"
  }
}
